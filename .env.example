# --- LLM ---
ANTHROPIC_API_KEY=

# --- Signals (Phase 1) ---
SERPAPI_KEY=
TIKTOK_CREATIVE_CENTER_TOKEN=

# --- Sourcing + Fulfilment (Phase 1 sourcing, Phase 3 auto-order) ---
CJ_API_KEY=

# --- Storefront (Phase 2) ---
SHOPIFY_ADMIN_TOKEN=
SHOPIFY_STORE_DOMAIN=
# Only needed to RUN `drift shopify-install` to mint SHOPIFY_ADMIN_TOKEN above.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_SCOPES=write_products,read_products
# Must EXACTLY match a Redirect URL allow-listed in the Shopify dev app config.
SHOPIFY_INSTALL_REDIRECT_URL=http://localhost:8765/callback
SHOPIFY_INSTALL_CALLBACK_HOST=0.0.0.0
SHOPIFY_INSTALL_CALLBACK_PORT=8765

# --- Ads (Phase 3) ---
META_MARKETING_TOKEN=
META_AD_ACCOUNT_ID=
TIKTOK_MARKETING_TOKEN=
TIKTOK_ADVERTISER_ID=

# --- Persistence ---
DATABASE_URL=sqlite:///drift.db

# --- Mock mode (default: live) ---
# Master switch. Each layer falls back to this if its specific switch is unset.
MOCK_MODE=false
# Per-layer overrides (true|false). Leave blank to inherit MOCK_MODE.
MOCK_SIGNALS=
MOCK_SOURCING=
MOCK_LLM=
MOCK_STOREFRONT=
MOCK_ADS=
MOCK_FULFILMENT=

# --- Scoring weights (must sum to 1.0) ---
SCORING_W_TREND=0.35
SCORING_W_MARGIN=0.25
SCORING_W_SUPPLIER=0.25
SCORING_W_SATURATION=0.15
SCORING_SURFACE_THRESHOLD=0.60

# --- Kill rule thresholds ---
KILL_ROAS_DAYS=3
KILL_TREND_DAYS=5

# --- Focus mode ---
# Empty = run all niches; set to a single niche to lock the store ("kids", "home"...).
# Comma-separated for a curated multi-niche store.
FOCUS_CATEGORIES=
